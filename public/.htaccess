# Apache config for cPanel / shared hosting
# SPA routing, compression, caching, security headers

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # === Force HTTPS (genuinoinvestments.ch) ===
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !=https
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # === Force non-www → www (or change to opposite if preferred) ===
  # Currently primary domain is the apex genuinoinvestments.ch, redirect www → apex.
  RewriteCond %{HTTP_HOST} ^www\.genuinoinvestments\.ch$ [NC]
  RewriteRule ^(.*)$ https://genuinoinvestments.ch/$1 [L,R=301]

  # === Per-language sitemaps proxied to Lovable Cloud edge function ===
  RewriteRule ^sitemap-index\.xml$ https://eyvfrocuuhxleroghybv.supabase.co/functions/v1/generate-sitemap?type=index [P,L]
  RewriteRule ^sitemap-(pt|en|fr|de)\.xml$ https://eyvfrocuuhxleroghybv.supabase.co/functions/v1/generate-sitemap?type=lang&lang=$1 [P,L]

  # SPA fallback
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# GZIP compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf font/woff font/woff2
</IfModule>

# Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "(service-worker|sw)\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(js|css|woff2?|ttf|otf|jpg|jpeg|png|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # === Security & SSL-friendly headers ===
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(self), microphone=(), camera=()"
  # HSTS — 1 year, includeSubDomains, preload-ready (only sent over HTTPS)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
  # Upgrade insecure requests at browser level
  Header always set Content-Security-Policy "upgrade-insecure-requests" env=HTTPS

  # Correct content-type for sitemap files
  <FilesMatch "\.xml$">
    Header set Content-Type "application/xml; charset=utf-8"
  </FilesMatch>
</IfModule>

# MIME types
<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType application/json .json
  AddType application/manifest+json .webmanifest
  AddType image/webp .webp
  AddType image/svg+xml .svg
  AddType font/woff .woff
  AddType font/woff2 .woff2
</IfModule>

# Block sensitive files
<FilesMatch "(^\.|\.env|\.git|\.md|package(-lock)?\.json|tsconfig.*\.json|vite\.config\.|bun\.lock)">
  Require all denied
</FilesMatch>

DirectoryIndex index.html
Options -Indexes
